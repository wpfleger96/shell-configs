@_register("macos")
def _macos_caches() -> list[ScanTarget]:
    home = Path.home()
    targets: list[ScanTarget] = [
        ScanTarget(
            path=home / "Library" / "Caches" / "Homebrew",
            label=str(home / "Library" / "Caches" / "Homebrew"),
            category="cache",
            tier=1,
            cleanup_cmd=["brew", "cleanup"],
            tool_name="brew",
        ),
        ScanTarget(
            path=home / "Library" / "Caches" / "hermit",
            label=str(home / "Library" / "Caches" / "hermit"),
            category="cache",
            tier=2,
        ),
        ScanTarget(
            path=home / "Library" / "Developer" / "Xcode" / "DerivedData",
            label=str(home / "Library" / "Developer" / "Xcode" / "DerivedData"),
            category="cache",
            tier=2,
        ),
        ScanTarget(
            path=home / "Library" / "Caches" / "CocoaPods",
            label=str(home / "Library" / "Caches" / "CocoaPods"),
            category="cache",
            tier=2,
        ),
    ]

    docker_raw = (
        home
        / "Library"
        / "Containers"
        / "com.docker.docker"
        / "Data"
        / "vms"
        / "0"
        / "data"
        / "Docker.raw"
    )
    if docker_raw.exists():
        t = ScanTarget(
            path=docker_raw,
            label=str(docker_raw),
            category="docker",
            tier=4,
            # Docker.raw is a VM disk image (file, not dir) — not directly deletable.
            # Reclaimed via docker system prune. Report-only: cleanup_cmd marks it
            # as tool-managed so _run_fix won't attempt shutil.rmtree on a file.
            cleanup_cmd=["docker", "system", "prune", "-af"],
            tool_name="docker",
        )
        t.size_bytes = _docker_raw_size(docker_raw)
        targets.append(t)

    return targets


