_SELECT_ALL = "__select_all__"
_SELECT_ALL_INCREMENTAL = "__select_all_incremental__"
_SELECT_ALL_CACHE = "__select_all_cache__"
_SELECT_ALL_TARGET = "__select_all_target__"
_SELECT_ALL_DOCKER = "__select_all_docker__"
_SELECT_ALL_DISCOVERY = "__select_all_discovery__"


def _interactive_select(
    targets: list[ScanTarget],
    discovery_items: list[DiscoveryItem] | None = None,
) -> tuple[list[ScanTarget], list[DiscoveryItem]]:
    from InquirerPy import inquirer
    from InquirerPy.base.control import Choice
    from InquirerPy.separator import Separator

    incrementals = [
        t for t in targets if t.category == "incremental" and t.size_bytes > 0
    ]
    caches = [t for t in targets if t.category == "cache" and t.size_bytes > 0]
    rust_targets = [t for t in targets if t.category == "target" and t.size_bytes > 0]
    docker_targets = [t for t in targets if t.category == "docker" and t.size_bytes > 0]
    discovery_with_size = [d for d in (discovery_items or []) if d.size_bytes > 0]

    all_with_size = [t for t in targets if t.size_bytes > 0]
    if not all_with_size and not discovery_with_size:
        console.print("[dim]No targets with size > 0 found.[/dim]")
        return [], []

    choices: list = []
    # InquirerPy internally calls dataclasses.asdict() on Choice objects, which
    # recursively converts any nested dataclass (like ScanTarget) into a plain dict.
    # Plain dicts are unhashable and can't be used as dict keys. To work around this,
    # we store integer indices as Choice.value and map them back to ScanTarget objects
    # via target_lookup. Strings (sentinel values) and ints survive asdict() unchanged.
    target_lookup: dict[int, ScanTarget | DiscoveryItem] = {}
    _next_idx = 0

    def _target_choice(t: ScanTarget | DiscoveryItem, name: str) -> Choice:
        nonlocal _next_idx
        idx = _next_idx
        _next_idx += 1
        target_lookup[idx] = t
        return Choice(value=idx, name=name)

    grand_total = _human_size(sum(t.size_bytes for t in all_with_size))
    choices.append(Choice(value=_SELECT_ALL, name=f"Select all ({grand_total})"))
    choices.append(Separator())

    section_map = {
        _SELECT_ALL_INCREMENTAL: incrementals,
        _SELECT_ALL_CACHE: caches,
        _SELECT_ALL_TARGET: rust_targets,
        _SELECT_ALL_DOCKER: docker_targets,
        _SELECT_ALL_DISCOVERY: discovery_with_size,
    }

    if incrementals:
        total = _human_size(sum(t.size_bytes for t in incrementals))
        choices.append(Separator(f"── Rust incremental caches ({total}) ──"))
        choices.append(
            Choice(
                value=_SELECT_ALL_INCREMENTAL,
                name=f"Select all Rust incremental caches ({total})",
            )
        )
        for t in sorted(incrementals, key=lambda t: t.size_bytes, reverse=True):
            choices.append(
                _target_choice(
                    t, f"  {_short_path(t.path)} ({_human_size(t.size_bytes)})"
                )
            )

    if caches:
        total = _human_size(sum(t.size_bytes for t in caches))
        choices.append(Separator(f"── Package caches ({total}) ──"))
        choices.append(
            Choice(
                value=_SELECT_ALL_CACHE,
                name=f"Select all Package caches ({total})",
            )
        )
        for t in sorted(caches, key=lambda t: t.size_bytes, reverse=True):
            choices.append(
                _target_choice(
                    t, f"  {_short_path(t.path)} ({_human_size(t.size_bytes)})"
                )
            )

    if rust_targets:
        total = _human_size(sum(t.size_bytes for t in rust_targets))
        choices.append(Separator(f"── Rust target dirs ({total}) ──"))
        choices.append(
            Choice(
                value=_SELECT_ALL_TARGET,
                name=f"Select all Rust target dirs ({total})",
            )
        )
        for t in sorted(rust_targets, key=lambda t: t.size_bytes, reverse=True):
            choices.append(
                _target_choice(
                    t, f"  {_short_path(t.path)} ({_human_size(t.size_bytes)})"
                )
            )

    if docker_targets:
        total = _human_size(sum(t.size_bytes for t in docker_targets))
        choices.append(Separator(f"── Docker ({total}) ──"))
        choices.append(
            Choice(
                value=_SELECT_ALL_DOCKER,
                name=f"Select all Docker ({total})",
            )
        )
        for t in docker_targets:
            name = (
                "  Docker system prune"
                if t.label == "docker system"
                else f"  {_short_path(t.path)} ({_human_size(t.size_bytes)})"
            )
            choices.append(_target_choice(t, name))

    if discovery_with_size:
        total = _human_size(sum(d.size_bytes for d in discovery_with_size))
        choices.append(Separator(f"── Discovered large files ({total}) ──"))
        choices.append(
            Choice(
                value=_SELECT_ALL_DISCOVERY,
                name=f"Select all discovered files ({total})",
            )
        )
        for d in sorted(discovery_with_size, key=lambda d: d.size_bytes, reverse=True):
            choices.append(
                _target_choice(
                    d, f"  {_short_path(d.path)} ({_human_size(d.size_bytes)})"
                )
            )

    selected_raw = inquirer.checkbox(
        message="Select items to clean (space to toggle, enter to confirm):",
        choices=choices,
    ).execute()

    if _SELECT_ALL in selected_raw:
        return all_with_size, []

    result_targets: list[ScanTarget] = []
    result_discovery: list[DiscoveryItem] = []
    for item in selected_raw:
        group = section_map.get(item)
        if group is not None:
            for g in group:
                if isinstance(g, DiscoveryItem):
                    result_discovery.append(g)
                else:
                    result_targets.append(g)
        elif isinstance(item, int) and item in target_lookup:
            obj = target_lookup[item]
            if isinstance(obj, DiscoveryItem):
                result_discovery.append(obj)
            else:
                result_targets.append(obj)

    seen: set[int] = set()
    deduped_targets: list[ScanTarget] = []
    for t in result_targets:
        if id(t) not in seen:
            seen.add(id(t))
            deduped_targets.append(t)
    deduped_discovery: list[DiscoveryItem] = []
    for d in result_discovery:
        if id(d) not in seen:
            seen.add(id(d))
            deduped_discovery.append(d)
    return deduped_targets, deduped_discovery


def _run_fix_selected(
    targets: list[ScanTarget],
    discovery_items: list[DiscoveryItem] | None = None,
    cache: SizeCache | None = None,
) -> None:
    root = "C:\\" if sys.platform == "win32" else "/"
    before_free = shutil.disk_usage(root).free

    console.print()
    console.print("[bold]=== Cleanup ===[/bold]")
    console.print()

    attempted = _execute_cleanup(targets)

    if discovery_items:
        discovery_attempted = _execute_discovery_cleanup(discovery_items)
        attempted.extend(discovery_attempted)

    if cache is not None and attempted:
        cache.invalidate(attempted)

    console.print()
    after_free = shutil.disk_usage(root).free
    _print_cleanup_summary(before_free, after_free)


