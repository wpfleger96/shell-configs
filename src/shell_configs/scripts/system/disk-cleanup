_MIN_DISPLAY_BYTES = 1024 * 1024  # 1 MB


def _print_section(
    title: str,
    description: str,
    items: list[ScanTarget],
    term_width: int,
) -> int:
    console.print(f"[blue]{title}[/blue] [dim]({description})[/dim]:")
    shown = [
        t
        for t in sorted(items, key=lambda t: t.size_bytes, reverse=True)
        if t.size_bytes >= _MIN_DISPLAY_BYTES
    ]
    if shown:
        for line in _format_rows(shown, term_width):
            console.print(line)
    else:
        console.print("  [dim](none found)[/dim]")
    subtotal = sum(t.size_bytes for t in items)
    console.print(f"  [bold]Subtotal: {_human_size(subtotal)}[/bold]")
    console.print()
    return subtotal


def _print_report(targets: list[ScanTarget]) -> None:
    console.print("[bold]Disk Usage Report[/bold]")
    console.print("=================")

    root = "C:\\" if sys.platform == "win32" else "/"
    usage = shutil.disk_usage(root)
    free = usage.free
    total = usage.total
    pct_used = int((total - free) * 100 / total) if total else 0
    console.print(
        f"Disk: [bold]{_human_size(free)}[/bold] free [dim]/ {_human_size(total)} total ({pct_used}% used)[/dim]"
    )
    console.print()

    incrementals = [t for t in targets if t.category == "incremental"]
    rust_targets = [t for t in targets if t.category == "target"]
    caches = [t for t in targets if t.category == "cache"]
    docker_targets = [t for t in targets if t.category == "docker"]

    tw = console.width
    total_inc = _print_section(
        "Rust incremental caches",
        "safe to clear, first rebuild slightly slower",
        incrementals,
        tw,
    )
    _print_section(
        "Rust target dirs",
        "full — clearing requires full rebuild",
        rust_targets,
        tw,
    )
    total_cache = _print_section(
        "Package caches",
        "safe to clear, re-downloaded on demand",
        caches,
        tw,
    )

    # --- Docker ---
    docker_files = [t for t in docker_targets if t.label != "docker system"]
    docker_daemon = [t for t in docker_targets if t.label == "docker system"]
    if docker_files or docker_daemon:
        console.print("[blue]Docker[/blue]:")
        if docker_files:
            for line in _format_rows(docker_files, tw):
                console.print(line)
        if docker_daemon:
            console.print(
                "  [dim]docker daemon running — run [/dim][cyan]docker system prune[/cyan][dim] to reclaim[/dim]"
            )
        console.print()

    total_reclaimable = total_inc + total_cache
    console.print(
        f"[green bold]Total reclaimable (incremental + caches): {_human_size(total_reclaimable)}[/green bold]"
    )


