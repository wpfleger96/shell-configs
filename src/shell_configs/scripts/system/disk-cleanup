        help="interactive (default), check, or fix (all tiers)",
    )
    parser.add_argument(
        "-y",
        "--yes",
        action="store_true",
        help="Skip confirmation prompts",
    )
    default_dev_dir = Path(
        os.environ.get("DISK_CLEANUP_DEV_DIR", str(Path.home() / "Development"))
    )
    parser.add_argument(
        "--dev-dir",
        type=Path,
        default=default_dev_dir,
        help=f"Development directory to scan (default: $DISK_CLEANUP_DEV_DIR or ~/Development, currently: {_short_path(default_dev_dir)})",
    )
    parser.add_argument(
        "--no-color",
        action="store_true",
        help="Disable colored output",
    )
    parser.add_argument(
        "--workers",
        type=int,
        default=_DEFAULT_WORKERS,
        help=f"Parallel thread count for size computation (default: {_DEFAULT_WORKERS}, based on CPU count, capped at 16)",
    )
    parser.add_argument(
        "--cache-ttl",
        type=float,
        default=300.0,
        help="Cache TTL for du results in seconds (default: 300, 0 to disable)",
    )
    parser.add_argument(
        "--no-cache",
        action="store_true",
        help="Bypass size cache and force fresh du scan",
    )
    parser.add_argument(
        "--skip-discover",
        action="store_true",
        help="Skip discovery scan (fast, known-caches-only mode)",
    )
    parser.add_argument(
        "--scan-dir",
        type=Path,
        action="append",
        dest="scan_dirs",
        default=None,
        metavar="PATH",
        help="Root(s) to scan for large files (repeatable, default: ~/)",
    )
    parser.add_argument(
        "--discover-top",
        type=int,
        default=20,
        metavar="N",
        help="Max items per category from discovery (default: 20)",
    )
    parser.add_argument(
        "--discover-min-size",
        type=_parse_size_arg,
        default=100 * 1024 * 1024,
        help="Min item size for discovery (e.g. 100M, 1G; default: 100M)",
    )
    parser.add_argument(
        "--stale-days",
        type=int,
        default=90,
        help="Days before an item is flagged as stale (default: 90)",
    )
    parser.add_argument(
        "--high-risk-dir",
        type=Path,
        action="append",
        dest="high_risk_dirs",
        default=None,
        metavar="PATH",
        help="Directory flagged for staleness (repeatable, default: ~/Downloads)",
    )
    args = parser.parse_args()

    if args.command == "interactive" and args.yes:
        parser.error("--yes cannot be used with interactive mode")

    if args.discover_top is not None and args.discover_top <= 0:
        parser.error("--discover-top must be positive")
    if args.stale_days is not None and args.stale_days <= 0:
        parser.error("--stale-days must be positive")

    if args.no_color:
        global console
        console = Console(no_color=True)

    dev_dir = args.dev_dir.resolve()
    home = Path.home().resolve()
    if dev_dir == home or dev_dir == Path("/"):
        parser.error("--dev-dir must not be home or root itself")
    if not str(dev_dir).startswith(str(home) + os.sep):
        parser.error(f"--dev-dir must be under $HOME, got: {dev_dir}")

    scan_dirs = args.scan_dirs or [Path.home()]
    high_risk_dirs = args.high_risk_dirs or [Path.home() / "Downloads"]

    cache_dir = Path(os.environ.get("XDG_CACHE_HOME", str(Path.home() / ".cache")))
    cache_path = cache_dir / "disk-cleanup" / "sizes.json"
    cache = (
        None
        if (args.no_cache or args.cache_ttl == 0)
        else SizeCache(cache_path, args.cache_ttl)
    )

    targets, discovery_items = _scan(
        dev_dir,
        args.workers,
        cache=cache,
        skip_discover=args.skip_discover,
        scan_dirs=scan_dirs,
        discover_top_n=args.discover_top,
        discover_min_size=args.discover_min_size,
        stale_days=args.stale_days,
        high_risk_dirs=high_risk_dirs,
    )

    if args.command == "check":
        _print_report(targets)
        if not args.skip_discover and discovery_items:
            _print_discovery_report(discovery_items, console.width)

    elif args.command == "fix":
        _print_report(targets)
        if not args.skip_discover and discovery_items:
            _print_discovery_report(discovery_items, console.width)
            console.print()
            console.print(
                "[dim]Discovered items require manual review — use interactive mode to select for deletion.[/dim]"
            )
        _run_fix(targets, skip_confirm=args.yes, cache=cache)

    elif args.command == "interactive":
        _print_report(targets)
        if not args.skip_discover and discovery_items:
            _print_discovery_report(discovery_items, console.width)
        selected_targets, selected_discovery = _interactive_select(
            targets, discovery_items if not args.skip_discover else None
        )
        if selected_targets or selected_discovery:
            _run_fix_selected(selected_targets, selected_discovery, cache=cache)


if __name__ == "__main__":
    main()
