@_register("wsl")
def _wsl_caches() -> list[ScanTarget]:
    targets: list[ScanTarget] = []

    # Resolve Windows LOCALAPPDATA via cmd.exe + wslpath
    try:
        proc = subprocess.run(
            ["cmd.exe", "/c", "echo %LOCALAPPDATA%"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        if proc.returncode == 0:
            win_path = proc.stdout.strip()
            wsl_proc = subprocess.run(
                ["wslpath", "-u", win_path],
                capture_output=True,
                text=True,
                timeout=10,
            )
            if wsl_proc.returncode == 0:
                local_app_data = Path(wsl_proc.stdout.strip())
                targets.extend(
                    [
                        ScanTarget(
                            path=local_app_data / "Temp",
                            label=str(local_app_data / "Temp"),
                            category="cache",
                            tier=1,
                        ),
                        ScanTarget(
                            path=local_app_data / "npm-cache",
                            label=str(local_app_data / "npm-cache"),
                            category="cache",
                            tier=1,
                        ),
                    ]
                )
    except subprocess.TimeoutExpired, OSError:
        pass  # WSL path resolution failure is non-fatal

    return targets


