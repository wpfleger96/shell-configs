#!/usr/bin/env python3
from __future__ import annotations

import argparse
import concurrent.futures
import os
import shutil
import subprocess
import sys
import threading

from collections.abc import Callable, Generator
from contextlib import contextmanager
from dataclasses import dataclass
from pathlib import Path

# ---------------------------------------------------------------------------
# ANSI colors
# ---------------------------------------------------------------------------

_USE_COLOR = (
    sys.stdout.isatty()
    and not os.environ.get("NO_COLOR")
    and "--no-color" not in sys.argv
)

if _USE_COLOR:
    RED = "\033[0;31m"
    GREEN = "\033[0;32m"
    YELLOW = "\033[1;33m"
    BLUE = "\033[0;34m"
    CYAN = "\033[0;36m"
    BOLD = "\033[1m"
    DIM = "\033[2m"
    NC = "\033[0m"
else:
    RED = GREEN = YELLOW = BLUE = CYAN = BOLD = DIM = NC = ""

# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------


def _detect_platform() -> str:
    if sys.platform == "win32":
        return "windows"
    if sys.platform == "darwin":
        return "macos"
    if sys.platform == "linux":
        try:
            with open("/proc/version") as f:
                v = f.read().lower()
                if "microsoft" in v or "wsl" in v:
                    return "wsl"
        except OSError:
            pass
        return "linux"
    return "linux"


PLATFORM = _detect_platform()

# ---------------------------------------------------------------------------
# Data model
# ---------------------------------------------------------------------------


@dataclass
class ScanTarget:
    path: Path
    label: str
    category: str  # "incremental" | "target" | "cache" | "docker"
    tier: int  # 1=incremental/safe caches, 2=full caches, 3=Rust targets, 4=Docker
    cleanup_cmd: list[str] | None = (
        None  # None => shutil.rmtree; list => subprocess args
    )
    tool_name: str | None = None  # required tool (checked via shutil.which)
    size_bytes: int = 0


# ---------------------------------------------------------------------------
# Platform target registry
# ---------------------------------------------------------------------------

_TARGET_BUILDERS: dict[str, list[Callable[[], list[ScanTarget]]]] = {}


def _register(*platforms: str) -> Callable:
    def decorator(fn: Callable) -> Callable:
        for p in platforms:
            _TARGET_BUILDERS.setdefault(p, [])
            _TARGET_BUILDERS[p].append(fn)
        return fn

    return decorator


# ---------------------------------------------------------------------------
# Size computation
# ---------------------------------------------------------------------------


def _du_size_bytes(path: Path) -> int:
    """Get directory size using du -sk. Falls back to 0 on error."""
    try:
        result = subprocess.run(
            ["du", "-sk", str(path)], capture_output=True, text=True, timeout=300
        )
        if result.returncode == 0:
            return int(result.stdout.split()[0]) * 1024
    except (subprocess.TimeoutExpired, ValueError, IndexError, OSError):
        pass
    return 0


def _compute_sizes_parallel(targets: list[ScanTarget], max_workers: int = 8) -> None:
    to_scan = [t for t in targets if t.path.exists() and t.category != "docker"]
    with concurrent.futures.ThreadPoolExecutor(max_workers=max_workers) as pool:
        futures = {pool.submit(_du_size_bytes, t.path): t for t in to_scan}
        for future in concurrent.futures.as_completed(futures):
            target = futures[future]
            try:
                target.size_bytes = future.result()
            except Exception:
                target.size_bytes = 0


def _docker_raw_size(path: Path) -> int:
    try:
        st = os.stat(path)
        if hasattr(st, "st_blocks"):
            # st_blocks reports 512-byte blocks actually allocated (sparse-file aware)
            return st.st_blocks * 512
        return st.st_size
    except OSError:
        return 0


# ---------------------------------------------------------------------------
# Dev tree scanner
# ---------------------------------------------------------------------------


def _scan_dev_tree(
    dev_dir: Path, max_depth: int = 6
) -> tuple[list[ScanTarget], list[ScanTarget]]:
    targets: list[ScanTarget] = []
    incrementals: list[ScanTarget] = []
    _SKIP_NAMES = frozenset({".git", "node_modules", "__pycache__"})

    stack: list[tuple[Path, int]] = [(dev_dir, 0)]
    while stack:
        current, depth = stack.pop()
        if depth > max_depth:
            continue
        try:
            entries = list(os.scandir(current))
        except (PermissionError, OSError):
            continue

        if current.name == "target":
            child_names = {e.name for e in entries if e.is_dir(follow_symlinks=False)}
            if "debug" in child_names or "release" in child_names:
                targets.append(
                    ScanTarget(
                        path=current,
                        label=str(current),
                        category="target",
                        tier=3,
                    )
                )
                for variant in ("debug", "release"):
                    inc = current / variant / "incremental"
                    if not inc.is_symlink() and inc.is_dir():
                        incrementals.append(
                            ScanTarget(
                                path=inc,
                                label=str(inc),
                                category="incremental",
                                tier=1,
                            )
                        )
                continue  # prune — don't descend into target/

        for entry in entries:
            if not entry.is_dir(follow_symlinks=False):
                continue
            if entry.name in _SKIP_NAMES:
                continue
            stack.append((Path(entry.path), depth + 1))

    return targets, incrementals


