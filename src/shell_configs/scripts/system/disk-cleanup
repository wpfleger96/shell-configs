# Output formatting
# ---------------------------------------------------------------------------


def _human_size(nbytes: int) -> str:
    if nbytes >= 1024**3:
        return f"{nbytes / 1024**3:.1f}G"
    elif nbytes >= 1024**2:
        return f"{nbytes / 1024**2:.0f}M"
    elif nbytes >= 1024:
        return f"{nbytes / 1024:.0f}K"
    return f"{nbytes}B"


def _color_size(nbytes: int) -> str:
    text = _human_size(nbytes)
    if nbytes >= 10 * 1024**3:
        return f"[red]{text}[/red]"
    elif nbytes >= 1024**3:
        return f"[yellow]{text}[/yellow]"
    return text


def _short_path(p: Path) -> str:
    home = str(Path.home())
    s = str(p)
    return s.replace(home, "~", 1) if s.startswith(home) else s


def _format_rows(items: list[ScanTarget], term_width: int) -> list[str]:
    SIZE_COL = 8
    INDENT = 2
    max_path_width = term_width - INDENT - SIZE_COL
    rows = []
    for t in items:
        path_str = _short_path(t.path)
        if len(path_str) > max_path_width:
            path_str = "…" + path_str[-(max_path_width - 1) :]
        plain_size = _human_size(t.size_bytes)
        padding = term_width - INDENT - len(path_str) - len(plain_size)
        rows.append(f"  {path_str}{' ' * max(1, padding)}{_color_size(t.size_bytes)}")
    return rows


# ---------------------------------------------------------------------------
# Scan
# ---------------------------------------------------------------------------


def _scan(
    dev_dir: Path,
    workers: int,
    cache: SizeCache | None = None,
    *,
    skip_discover: bool = False,
    scan_dirs: list[Path] | None = None,
    discover_top_n: int = 20,
    discover_min_size: int = 100 * 1024 * 1024,
    stale_days: int = 90,
    high_risk_dirs: list[Path] | None = None,
) -> tuple[list[ScanTarget], list[DiscoveryItem]]:
    from concurrent.futures import Future, ThreadPoolExecutor, as_completed

    from rich.progress import Progress, SpinnerColumn, TextColumn

    all_targets: list[ScanTarget] = []
    du_futures: dict[Future[int | None], ScanTarget] = {}
    cache_hits = 0

    def _submit_du(target: ScanTarget, pool: ThreadPoolExecutor) -> None:
        all_targets.append(target)
        if target.path.exists() and target.category != "docker":
            if cache is not None:
                cached = cache.get(target.path)
                if cached is not None:
                    target.size_bytes = cached
                    nonlocal cache_hits
                    cache_hits += 1
                    return
            du_futures[pool.submit(_du_size_bytes, target.path)] = target

    def _run_builders() -> list[ScanTarget]:
        """Run all platform target builders. Runs in a background thread."""
        result: list[ScanTarget] = []
        for fn in _TARGET_BUILDERS.get(PLATFORM, []):
            result.extend(fn())
        # WSL inherits all Linux cache locations on top of its own
        if PLATFORM == "wsl":
            for fn in _TARGET_BUILDERS.get("linux", []):
                result.extend(fn())
        return result

    progress = Progress(
        SpinnerColumn(),
        TextColumn("[progress.description]{task.description}"),
        console=console,
        transient=True,
    )

    with progress:
        scan_task = progress.add_task(
            "[cyan]Scanning development directories...", total=None
        )
        builders_task = progress.add_task(
            "[cyan]Resolving platform caches...", total=None
        )
        sizes_task = progress.add_task("[cyan]Computing sizes...", total=None)

        with ThreadPoolExecutor(max_workers=workers) as pool:
            # Submit builders to run concurrently with the dev-tree walk
            builders_future = pool.submit(_run_builders)

            # Walk dev tree on main thread, submit du futures as targets are found
            for target in _scan_dev_tree(dev_dir):
                _submit_du(target, pool)

            progress.update(
                scan_task, description="[green]Scanning development directories"
            )

            # Collect builder results, submit their du futures
            builder_targets = builders_future.result()
            for target in builder_targets:
                _submit_du(target, pool)

            progress.update(
                builders_task, description="[green]Resolving platform caches"
            )

            # Submit discovery walk concurrently with du size computation
            discovery_future = None
            if not skip_discover:
                discovery_task = progress.add_task(
                    "[cyan]Scanning for large files...", total=None
                )
                registry_paths = frozenset(t.path.resolve() for t in all_targets)
                skip_paths = _build_discovery_skip_paths(registry_paths, dev_dir)

                def _discovery_progress(n: int) -> None:
                    progress.update(
                        discovery_task,
                        description=f"[cyan]Scanning for large files ({n} dirs)...",
                    )

                discovery_future = pool.submit(
                    _scan_discovery_walk,
                    scan_dirs or [Path.home()],
                    discover_min_size,
                    discover_top_n,
                    skip_paths,
                    high_risk_dirs or [Path.home() / "Downloads"],
                    stale_days,
                    _discovery_progress,
                )

            # Update sizes task with total count now that all futures are submitted
            total_du = len(du_futures)
            total_sizes = cache_hits + total_du
            completed_du = 0
            if cache_hits > 0:
                progress.update(
                    sizes_task,
                    description=f"[cyan]Computing sizes ({cache_hits}/{total_sizes}, {cache_hits} cached)...",
                )
            else:
                progress.update(
                    sizes_task,
                    description=f"[cyan]Computing sizes (0/{total_sizes})...",
                )

            # Collect du results as they complete
            cache_updates: dict[str, tuple[int, float]] = {}
            now = time.time()
            for future in as_completed(du_futures):
                target = du_futures[future]
                try:
                    result = future.result()
                except Exception:
                    result = None
                if result is not None:
                    target.size_bytes = result
                    cache_updates[str(target.path.resolve())] = (result, now)
                else:
                    target.size_bytes = 0
                completed_du += 1
                progress.update(
                    sizes_task,
                    description=f"[cyan]Computing sizes ({completed_du + cache_hits}/{total_sizes}{f', {cache_hits} cached' if cache_hits else ''})...",
                )

            if cache is not None and cache_updates:
                cache.update(cache_updates)

            progress.update(sizes_task, description="[green]Computing sizes")

            # Collect discovery results (walk likely done or nearly done by now)
            if discovery_future is not None:
                discovery_items = discovery_future.result()
                progress.update(
                    discovery_task,
                    description="[green]Scanning for large files",
                )
            else:
                discovery_items = []

    return all_targets, discovery_items


