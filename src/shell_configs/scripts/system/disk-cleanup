_TIER_LABELS = {
    1: "Tier 1: Incremental caches and safe package caches",
    2: "Tier 2: Full package caches",
    3: "Tier 3: Rust target directories (requires full rebuild to restore)",
    4: "Tier 4: Docker",
}


def _confirm(prompt: str) -> bool:
    console.print(f"[yellow]{prompt}[/yellow]")
    try:
        reply = input("Continue? (y/N) ").strip().lower()
    except EOFError:
        return False
    return reply in ("y", "yes")


def _execute_cleanup(targets: list[ScanTarget]) -> list[Path]:
    attempted: list[Path] = []
    docker_prune = [t for t in targets if t.label == "docker system"]
    regular = [t for t in targets if t.label != "docker system"]

    for t in regular:
        display = _short_path(t.path)
        if t.cleanup_cmd is not None:
            if t.tool_name and not shutil.which(t.tool_name):
                console.print(
                    f"  [yellow]Skipping {display} ({t.tool_name} not found)[/yellow]"
                )
                continue
            console.print(
                f"  Running {' '.join(t.cleanup_cmd)} ({display}, {_human_size(t.size_bytes)})..."
            )
            try:
                subprocess.run(t.cleanup_cmd, check=False, timeout=600)
            except subprocess.TimeoutExpired:
                console.print(
                    f"  [yellow]Warning: {t.cleanup_cmd[0]} timed out[/yellow]"
                )
            attempted.append(t.path)
        else:
            console.print(f"  Removing {display} ({_human_size(t.size_bytes)})...")
            shutil.rmtree(t.path, onerror=lambda *a: None)
            attempted.append(t.path)

    if docker_prune:
        console.print("  Running docker system prune -af ...")
        try:
            subprocess.run(
                ["docker", "system", "prune", "-af"], check=False, timeout=600
            )
        except subprocess.TimeoutExpired:
            console.print("  [yellow]Warning: docker system prune timed out[/yellow]")
        console.print("  Running docker builder prune -af ...")
        try:
            subprocess.run(
                ["docker", "builder", "prune", "-af"], check=False, timeout=600
            )
        except subprocess.TimeoutExpired:
            console.print("  [yellow]Warning: docker builder prune timed out[/yellow]")

    return attempted


def _print_cleanup_summary(before_free: int, after_free: int) -> None:
    root = "C:\\" if sys.platform == "win32" else "/"
    freed = after_free - before_free

    console.print("[bold]Cleanup complete[/bold]")
    console.print("================")
    if freed > 0:
        console.print(f"Freed: [green]{_human_size(freed)}[/green]")
    else:
        console.print("Freed: 0 (space may be reclaimed asynchronously by APFS)")

    total = shutil.disk_usage(root).total
    before_pct = int((total - before_free) * 100 / total) if total else 0
    after_pct = int((total - after_free) * 100 / total) if total else 0
    console.print(
        f"Before: {_human_size(before_free)} free / {_human_size(total)} total ({before_pct}% used)"
    )
    console.print(
        f"After:  {_human_size(after_free)} free / {_human_size(total)} total ({after_pct}% used)"
    )


def _run_fix(
    targets: list[ScanTarget], skip_confirm: bool, cache: SizeCache | None = None
) -> None:
    root = "C:\\" if sys.platform == "win32" else "/"
    before_free = shutil.disk_usage(root).free
    all_attempted: list[Path] = []

    console.print()
    console.print("[bold]=== Cleanup ===[/bold]")
    console.print()

    for tier in (1, 2, 3, 4):
        tier_targets = [
            t
            for t in targets
            if t.tier == tier and (t.size_bytes > 0 or t.label == "docker system")
        ]

        if not tier_targets:
            continue

        tier_total = sum(
            t.size_bytes for t in tier_targets if t.label != "docker system"
        )
        label = _TIER_LABELS.get(tier, f"Tier {tier}")
        console.print(f"[cyan]{label} (~{_human_size(tier_total)})[/cyan]")

        if not skip_confirm and not _confirm(f"Clean tier {tier}?"):
            console.print("  [yellow]Skipped[/yellow]")
            console.print()
            continue

        all_attempted.extend(_execute_cleanup(tier_targets))
        console.print("  [green]Done[/green]")
        console.print()

    if cache is not None and all_attempted:
        cache.invalidate(all_attempted)

    after_free = shutil.disk_usage(root).free
    _print_cleanup_summary(before_free, after_free)


