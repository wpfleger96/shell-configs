# ---------------------------------------------------------------------------
# Platform detection
# ---------------------------------------------------------------------------


def _detect_platform() -> str:
    if sys.platform == "win32":
        return "windows"
    if sys.platform == "darwin":
        return "macos"
    if sys.platform == "linux":
        try:
            with open("/proc/version") as f:
                v = f.read().lower()
                if "microsoft" in v or "wsl" in v:
                    return "wsl"
        except OSError:
            pass
        return "linux"
    return "linux"


PLATFORM = _detect_platform()

# ---------------------------------------------------------------------------
# Data model
# ---------------------------------------------------------------------------


@dataclass
class ScanTarget:
    path: Path
    label: str
    category: str  # "incremental" | "target" | "cache" | "docker"
    tier: int  # 1=incremental/safe caches, 2=full caches, 3=Rust targets, 4=Docker
    cleanup_cmd: list[str] | None = (
        None  # None => shutil.rmtree; list => subprocess args
    )
    tool_name: str | None = None  # required tool (checked via shutil.which)
    size_bytes: int = 0


# ---------------------------------------------------------------------------
# Platform target registry
# ---------------------------------------------------------------------------

_TARGET_BUILDERS: dict[str, list[Callable[[], list[ScanTarget]]]] = {}


def _register(*platforms: str) -> Callable:
    def decorator(fn: Callable) -> Callable:
        for p in platforms:
            _TARGET_BUILDERS.setdefault(p, [])
            _TARGET_BUILDERS[p].append(fn)
        return fn

    return decorator


# ---------------------------------------------------------------------------
# Size computation
# ---------------------------------------------------------------------------


def _du_size_bytes(path: Path) -> int | None:
    try:
        result = subprocess.run(
            ["du", "-sk", str(path)], capture_output=True, text=True, timeout=300
        )
        if result.returncode == 0:
            return int(result.stdout.split()[0]) * 1024
    except (subprocess.TimeoutExpired, ValueError, IndexError, OSError):
        pass
    return None


def _docker_raw_size(path: Path) -> int:
    try:
        st = os.stat(path)
        if hasattr(st, "st_blocks"):
            # st_blocks reports 512-byte blocks actually allocated (sparse-file aware)
            return st.st_blocks * 512
        return st.st_size
    except OSError:
        return 0


# ---------------------------------------------------------------------------
# Size cache
# ---------------------------------------------------------------------------


class SizeCache:
    def __init__(self, path: Path, ttl: float):
        self._path = path
        self._ttl = ttl
        self._data: dict[
            str, tuple[int, float]
        ] = {}  # str(path) -> (size_bytes, timestamp)
        self._load()

    def _load(self) -> None:
        # Read JSON file, prune expired entries only (NOT existence checks — that's done by _submit_du).
        # Silently discard any parse/IO error (self._data stays empty = fresh scan).
        try:
            raw = json.loads(self._path.read_text())
            now = time.time()
            self._data = {
                k: (v["size_bytes"], v["ts"])
                for k, v in raw.items()
                if isinstance(v, dict)
                and isinstance(v.get("size_bytes"), int)
                and now - v.get("ts", 0) <= self._ttl
            }
        except (OSError, json.JSONDecodeError, KeyError, TypeError, AttributeError):
            self._data = {}

    def get(self, path: Path) -> int | None:
        entry = self._data.get(str(path.resolve()))
        if entry is None:
            return None
        return entry[0]

    def update(self, entries: dict[str, tuple[int, float]]) -> None:
        self._data.update(entries)
        self._save()

    def invalidate(self, paths: list[Path]) -> None:
        resolved = [p.resolve() for p in paths]
        to_remove: list[str] = []
        for key in self._data:
            key_path = Path(key)
            for p in resolved:
                if (
                    key_path == p
                    or key_path.is_relative_to(p)
                    or p.is_relative_to(key_path)
                ):
                    to_remove.append(key)
                    break
        for key in to_remove:
            del self._data[key]
        if to_remove:
            self._save()

    def _save(self) -> None:
        try:
            self._path.parent.mkdir(parents=True, exist_ok=True)
            data = {k: {"size_bytes": v[0], "ts": v[1]} for k, v in self._data.items()}
            fd = tempfile.NamedTemporaryFile(
                mode="w",
                dir=self._path.parent,
                suffix=".tmp",
                delete=False,
            )
            try:
                json.dump(data, fd)
                fd.close()
                os.replace(fd.name, self._path)
            except BaseException:
                fd.close()
                try:
                    os.unlink(fd.name)
                except OSError:
                    pass
                raise
        except OSError:
            pass


# ---------------------------------------------------------------------------
# Dev tree scanner
# ---------------------------------------------------------------------------


def _scan_dev_tree(
    dev_dir: Path, max_depth: int = 6
) -> Generator[ScanTarget, None, None]:
    _SKIP_NAMES = frozenset({".git", "node_modules", "__pycache__"})

    stack: list[tuple[Path, int]] = [(dev_dir, 0)]
    while stack:
        current, depth = stack.pop()
        if depth > max_depth:
            continue
        try:
            entries = list(os.scandir(current))
        except (PermissionError, OSError):
            continue

        if current.name == "target":
            child_names = {e.name for e in entries if e.is_dir(follow_symlinks=False)}
            if "debug" in child_names or "release" in child_names:
                yield ScanTarget(
                    path=current,
                    label=str(current),
                    category="target",
                    tier=3,
                )
                for variant in ("debug", "release"):
                    inc = current / variant / "incremental"
                    if not inc.is_symlink() and inc.is_dir():
                        yield ScanTarget(
                            path=inc,
                            label=str(inc),
                            category="incremental",
                            tier=1,
                        )
                continue  # prune — don't descend into target/

        for entry in entries:
            if not entry.is_dir(follow_symlinks=False):
                continue
            if entry.name in _SKIP_NAMES:
                continue
            stack.append((Path(entry.path), depth + 1))


