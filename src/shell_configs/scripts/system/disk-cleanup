@_register("wsl")
def _wsl_caches() -> list[ScanTarget]:
    targets: list[ScanTarget] = []

    # Resolve Windows LOCALAPPDATA via cmd.exe + wslpath
    try:
        proc = subprocess.run(
            ["cmd.exe", "/c", "echo %LOCALAPPDATA%"],
            capture_output=True,
            text=True,
            timeout=10,
        )
        if proc.returncode == 0:
            win_path = proc.stdout.strip()
            wsl_proc = subprocess.run(
                ["wslpath", "-u", win_path],
                capture_output=True,
                text=True,
                timeout=10,
            )
            if wsl_proc.returncode == 0:
                local_app_data = Path(wsl_proc.stdout.strip())
                targets.extend(
                    [
                        ScanTarget(
                            path=local_app_data / "Temp",
                            label=str(local_app_data / "Temp"),
                            category="cache",
                            tier=1,
                        ),
                        ScanTarget(
                            path=local_app_data / "npm-cache",
                            label=str(local_app_data / "npm-cache"),
                            category="cache",
                            tier=1,
                        ),
                    ]
                )
    except (subprocess.TimeoutExpired, OSError):
        pass  # WSL path resolution failure is non-fatal

    return targets


@_register("windows")
def _windows_caches() -> list[ScanTarget]:
    local_app_data = os.environ.get("LOCALAPPDATA")
    home = Path.home()
    targets: list[ScanTarget] = []

    if local_app_data:
        lad = Path(local_app_data)
        targets.extend(
            [
                ScanTarget(
                    path=lad / "Temp",
                    label=str(lad / "Temp"),
                    category="cache",
                    tier=1,
                ),
                ScanTarget(
                    path=lad / "npm-cache",
                    label=str(lad / "npm-cache"),
                    category="cache",
                    tier=1,
                ),
            ]
        )

    targets.append(
        ScanTarget(
            path=home / ".nuget" / "packages",
            label=str(home / ".nuget" / "packages"),
            category="cache",
            tier=2,
        )
    )

    return targets


@_register("macos", "linux", "wsl", "windows")
def _docker_targets() -> list[ScanTarget]:
    if not shutil.which("docker"):
        return []
    try:
        result = subprocess.run(
            ["docker", "info"],
            capture_output=True,
            timeout=10,
        )
        if result.returncode != 0:
            return []
    except (subprocess.TimeoutExpired, OSError):
        return []

    # Sentinel target — no path, handled specially in report and fix
    return [
        ScanTarget(
            path=Path("/dev/null"),  # placeholder; category="docker" skips du
            label="docker system",
            category="docker",
            tier=4,
            cleanup_cmd=["docker", "system", "prune", "-af"],
            tool_name="docker",
        )
    ]


# ---------------------------------------------------------------------------
# Output formatting
# ---------------------------------------------------------------------------


def _human_size(nbytes: int) -> str:
    if nbytes >= 1024**3:
        return f"{nbytes / 1024**3:.1f}G"
    elif nbytes >= 1024**2:
        return f"{nbytes / 1024**2:.0f}M"
    elif nbytes >= 1024:
        return f"{nbytes / 1024:.0f}K"
    return f"{nbytes}B"


def _color_size(nbytes: int) -> str:
    text = _human_size(nbytes)
    if nbytes >= 10 * 1024**3:
        return f"{RED}{text}{NC}"
    elif nbytes >= 1024**3:
        return f"{YELLOW}{text}{NC}"
    return text


def _short_path(p: Path) -> str:
    home = str(Path.home())
    s = str(p)
    return s.replace(home, "~", 1) if s.startswith(home) else s


def _term_width() -> int:
    try:
        return os.get_terminal_size().columns
    except (ValueError, OSError):
        return 100


def _format_rows(items: list[ScanTarget], term_width: int) -> list[str]:
    SIZE_COL = 8
    INDENT = 2
    max_path_width = term_width - INDENT - SIZE_COL
    rows = []
    for t in items:
        path_str = _short_path(t.path)
        if len(path_str) > max_path_width:
            path_str = "…" + path_str[-(max_path_width - 1) :]
        plain_size = _human_size(t.size_bytes)
        padding = term_width - INDENT - len(path_str) - len(plain_size)
        rows.append(f"  {path_str}{' ' * max(1, padding)}{_color_size(t.size_bytes)}")
    return rows


# ---------------------------------------------------------------------------
# Spinner
# ---------------------------------------------------------------------------


@contextmanager
def _spinner(message: str) -> Generator[None, None, None]:
    if not sys.stderr.isatty():
        sys.stderr.write(f"{message}\n")
        yield
        return
    stop = threading.Event()

    def spin() -> None:
        chars = "⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
        i = 0
        while not stop.is_set():
            sys.stderr.write(f"\r{chars[i % len(chars)]} {message}")
            sys.stderr.flush()
            stop.wait(0.1)
            i += 1
        sys.stderr.write(f"\r{' ' * (len(message) + 3)}\r")
        sys.stderr.flush()

    t = threading.Thread(target=spin, daemon=True)
    t.start()
    try:
        yield
    finally:
        stop.set()
        t.join()


# ---------------------------------------------------------------------------
# Scan
# ---------------------------------------------------------------------------


def _scan(dev_dir: Path, workers: int) -> list[ScanTarget]:
    all_targets: list[ScanTarget] = []

    with _spinner("Scanning development directories..."):
        rust_targets, incrementals = _scan_dev_tree(dev_dir)
        all_targets.extend(rust_targets)
        all_targets.extend(incrementals)

    for fn in _TARGET_BUILDERS.get(PLATFORM, []):
        all_targets.extend(fn())
    # WSL inherits all Linux cache locations on top of its own
    if PLATFORM == "wsl":
        for fn in _TARGET_BUILDERS.get("linux", []):
            all_targets.extend(fn())

    with _spinner("Computing sizes..."):
        _compute_sizes_parallel(all_targets, max_workers=workers)

    return all_targets


# ---------------------------------------------------------------------------
# Report
# ---------------------------------------------------------------------------


_MIN_DISPLAY_BYTES = 1024 * 1024  # 1 MB


def _print_section(
    title: str,
    description: str,
    items: list[ScanTarget],
    term_width: int,
) -> int:
    print(f"{BLUE}{title}{NC} {DIM}({description}){NC}:")
    shown = [
        t
        for t in sorted(items, key=lambda t: t.size_bytes, reverse=True)
        if t.size_bytes >= _MIN_DISPLAY_BYTES
    ]
    if shown:
        for line in _format_rows(shown, term_width):
            print(line)
    else:
        print(f"  {DIM}(none found){NC}")
    subtotal = sum(t.size_bytes for t in items)
    print(f"  {BOLD}Subtotal: {_human_size(subtotal)}{NC}")
    print()
    return subtotal


def _print_report(targets: list[ScanTarget]) -> None:
    print(f"{BOLD}Disk Usage Report{NC}")
    print("=================")

    root = "C:\\" if sys.platform == "win32" else "/"
    usage = shutil.disk_usage(root)
    free = usage.free
    total = usage.total
    pct_used = int((total - free) * 100 / total) if total else 0
    print(
        f"Disk: {BOLD}{_human_size(free)}{NC} free {DIM}/ {_human_size(total)} total ({pct_used}% used){NC}"
    )
    print()

    incrementals = [t for t in targets if t.category == "incremental"]
    rust_targets = [t for t in targets if t.category == "target"]
    caches = [t for t in targets if t.category == "cache"]
    docker_targets = [t for t in targets if t.category == "docker"]

    tw = _term_width()
    total_inc = _print_section(
        "Rust incremental caches",
        "safe to clear, first rebuild slightly slower",
        incrementals,
        tw,
    )
    _print_section(
        "Rust target dirs",
        "full — clearing requires full rebuild",
        rust_targets,
        tw,
    )
    total_cache = _print_section(
        "Package caches",
        "safe to clear, re-downloaded on demand",
        caches,
        tw,
    )

    # --- Docker ---
    docker_files = [t for t in docker_targets if t.label != "docker system"]
    docker_daemon = [t for t in docker_targets if t.label == "docker system"]
    if docker_files or docker_daemon:
        print(f"{BLUE}Docker{NC}:")
        if docker_files:
            for line in _format_rows(docker_files, tw):
                print(line)
        if docker_daemon:
            print(
                f"  {DIM}docker daemon running — run {NC}{CYAN}docker system prune{NC}{DIM} to reclaim{NC}"
            )
        print()

    total_reclaimable = total_inc + total_cache
    print(
        f"{GREEN}{BOLD}Total reclaimable (incremental + caches): {_human_size(total_reclaimable)}{NC}"
    )


# ---------------------------------------------------------------------------
# Fix
# ---------------------------------------------------------------------------


_TIER_LABELS = {
    1: "Tier 1: Incremental caches and safe package caches",
    2: "Tier 2: Full package caches",
    3: "Tier 3: Rust target directories (requires full rebuild to restore)",
    4: "Tier 4: Docker",
}


def _confirm(prompt: str) -> bool:
    print(f"{YELLOW}{prompt}{NC}")
    try:
        reply = input("Continue? (y/N) ").strip().lower()
    except EOFError:
        return False
    return reply in ("y", "yes")


def _run_fix(targets: list[ScanTarget], skip_confirm: bool) -> None:
    root = "C:\\" if sys.platform == "win32" else "/"
    before_free = shutil.disk_usage(root).free

    print()
    print(f"{BOLD}=== Cleanup ==={NC}")
    print()

    for tier in (1, 2, 3, 4):
        tier_targets = [
            t
            for t in targets
            if t.tier == tier and t.size_bytes > 0 and t.label != "docker system"
        ]
        docker_prune = [
            t for t in targets if t.tier == tier and t.label == "docker system"
        ]

        if not tier_targets and not docker_prune:
            continue

        tier_total = sum(t.size_bytes for t in tier_targets)
        label = _TIER_LABELS.get(tier, f"Tier {tier}")
        print(f"{CYAN}{label} (~{_human_size(tier_total)}){NC}")

        if not skip_confirm and not _confirm(f"Clean tier {tier}?"):
            print(f"  {YELLOW}Skipped{NC}")
            print()
            continue

        for t in tier_targets:
            display = _short_path(t.path)
            if t.cleanup_cmd is not None:
                if t.tool_name and not shutil.which(t.tool_name):
                    print(f"  {YELLOW}Skipping {display} ({t.tool_name} not found){NC}")
                    continue
                print(
                    f"  Running {' '.join(t.cleanup_cmd)} ({display}, {_human_size(t.size_bytes)})..."
                )
                try:
                    subprocess.run(t.cleanup_cmd, check=False, timeout=600)
                except subprocess.TimeoutExpired:
                    print(f"  {YELLOW}Warning: {t.cleanup_cmd[0]} timed out{NC}")
            else:
                print(f"  Removing {display} ({_human_size(t.size_bytes)})...")
                shutil.rmtree(t.path, onerror=lambda *a: None)

        if docker_prune:
            print("  Running docker system prune -af ...")
            try:
                subprocess.run(
                    ["docker", "system", "prune", "-af"], check=False, timeout=600
                )
            except subprocess.TimeoutExpired:
                print(f"  {YELLOW}Warning: docker system prune timed out{NC}")
            print("  Running docker builder prune -af ...")
            try:
                subprocess.run(
                    ["docker", "builder", "prune", "-af"], check=False, timeout=600
                )
            except subprocess.TimeoutExpired:
                print(f"  {YELLOW}Warning: docker builder prune timed out{NC}")

        print(f"  {GREEN}Done{NC}")
        print()

    after_free = shutil.disk_usage(root).free
    freed = after_free - before_free

    print(f"{BOLD}Cleanup complete{NC}")
    print("================")
    if freed > 0:
        print(f"Freed: {GREEN}{_human_size(freed)}{NC}")
    else:
        print("Freed: 0 (space may be reclaimed asynchronously by APFS)")

    total = shutil.disk_usage(root).total
    before_pct = int((total - before_free) * 100 / total) if total else 0
    after_pct = int((total - after_free) * 100 / total) if total else 0
    print(
        f"Before: {_human_size(before_free)} free / {_human_size(total)} total ({before_pct}% used)"
    )
    print(
        f"After:  {_human_size(after_free)} free / {_human_size(total)} total ({after_pct}% used)"
    )


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="disk-cleanup",
        description="Cross-platform disk usage reporter and cleaner",
    )
    parser.add_argument(
        "command",
        nargs="?",
        default="check",
        choices=["check", "fix"],
        help="check (default) or fix",
    )
    parser.add_argument(
        "-y",
        "--yes",
        action="store_true",
        help="Skip confirmation prompts",
    )
    parser.add_argument(
        "--dev-dir",
        type=Path,
        default=Path(
            os.environ.get("DISK_CLEANUP_DEV_DIR", str(Path.home() / "Development"))
        ),
        help="Development directory to scan",
    )
    parser.add_argument(
        "--no-color",
        action="store_true",
        help="Disable colored output",
    )
    parser.add_argument(
        "--workers",
        type=int,
        default=8,
        help="Parallel thread count for size computation",
    )
    args = parser.parse_args()

    if args.no_color:
        global RED, GREEN, YELLOW, BLUE, CYAN, BOLD, DIM, NC
        RED = GREEN = YELLOW = BLUE = CYAN = BOLD = DIM = NC = ""

    dev_dir = args.dev_dir.resolve()
    home = Path.home().resolve()
    if dev_dir == home or dev_dir == Path("/"):
        parser.error("--dev-dir must not be home or root itself")
    if not str(dev_dir).startswith(str(home) + os.sep):
        parser.error(f"--dev-dir must be under $HOME, got: {dev_dir}")

    targets = _scan(dev_dir, args.workers)

    if args.command == "check":
        _print_report(targets)
    else:
        _print_report(targets)
        _run_fix(targets, skip_confirm=args.yes)


if __name__ == "__main__":
    main()
