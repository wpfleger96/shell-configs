def _categorize_path(p: Path) -> str:
    # Check compound .tar.gz before single suffix
    suffix = p.suffix.lower().lstrip(".")
    if suffix == "gz" and p.stem.endswith(".tar"):
        return "archives"
    category = _EXTENSION_CATEGORIES.get(suffix)
    if category is not None:
        return category
    mime, _ = mimetypes.guess_type(str(p))
    if mime is not None:
        return mime.split("/")[0]
    return "other"


def _human_age(mtime: float) -> str:
    days = int((time.time() - mtime) / 86400)
    if days >= 365:
        return f"{days // 365}y"
    return f"{days}d"


def _parse_size_arg(s: str) -> int:
    s = s.strip()
    suffixes = {"k": 1, "m": 2, "g": 3, "t": 4}
    lower = s.lower()
    if lower and lower[-1] in suffixes:
        exp = suffixes[lower[-1]]
        num_part = lower[:-1]
    else:
        exp = 0
        num_part = lower
    try:
        value = float(num_part)
    except ValueError:
        raise argparse.ArgumentTypeError(f"Invalid size: {s!r}")
    return int(value * (1024**exp))


def _allocated_size(st: os.stat_result) -> int:
    if hasattr(st, "st_blocks"):
        return st.st_blocks * 512
    return st.st_size


def _build_discovery_skip_paths(
    registry_paths: frozenset[Path], dev_dir: Path
) -> frozenset[Path]:
    home = Path.home()
    paths: set[Path] = set(registry_paths)
    paths.add(dev_dir.resolve())

    platform_extras: list[Path] = []
    if PLATFORM == "macos":
        platform_extras = [
            home / "Library",
            home / "Pictures" / "Photos Library.photoslibrary",
        ]
    elif PLATFORM in ("linux", "wsl"):
        platform_extras = [
            home / ".config",
            home / ".local" / "share",
        ]
    elif PLATFORM == "windows":
        localappdata = os.environ.get("LOCALAPPDATA", "")
        appdata = os.environ.get("APPDATA", "")
        if localappdata:
            platform_extras.append(Path(localappdata))
        if appdata:
            platform_extras.append(Path(appdata))

    for p in platform_extras:
        try:
            resolved = p.resolve()
            if resolved != Path(""):
                paths.add(resolved)
        except OSError:
            pass

    return frozenset(paths)


