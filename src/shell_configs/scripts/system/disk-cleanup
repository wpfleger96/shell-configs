def _confirm(prompt: str) -> bool:
    console.print(f"[yellow]{prompt}[/yellow]")
    try:
        reply = input("Continue? (y/N) ").strip().lower()
    except EOFError:
        return False
    return reply in ("y", "yes")


def _execute_cleanup(targets: list[ScanTarget]) -> list[Path]:
    attempted: list[Path] = []
    docker_prune = [t for t in targets if t.label == "docker system"]
    regular = [t for t in targets if t.label != "docker system"]

    for t in regular:
        display = _short_path(t.path)
        if t.cleanup_cmd is not None:
            if t.tool_name and not shutil.which(t.tool_name):
                console.print(
                    f"  [yellow]Skipping {display} ({t.tool_name} not found)[/yellow]"
                )
                continue
            console.print(
                f"  Running {' '.join(t.cleanup_cmd)} ({display}, {_human_size(t.size_bytes)})..."
            )
            try:
                subprocess.run(t.cleanup_cmd, check=False, timeout=600)
            except subprocess.TimeoutExpired:
                console.print(
                    f"  [yellow]Warning: {t.cleanup_cmd[0]} timed out[/yellow]"
                )
            attempted.append(t.path)
        else:
            console.print(f"  Removing {display} ({_human_size(t.size_bytes)})...")
            shutil.rmtree(t.path, onerror=lambda *a: None)
            attempted.append(t.path)

    if docker_prune:
        console.print("  Running docker system prune -af ...")
        try:
            subprocess.run(
                ["docker", "system", "prune", "-af"], check=False, timeout=600
            )
        except subprocess.TimeoutExpired:
            console.print("  [yellow]Warning: docker system prune timed out[/yellow]")
        console.print("  Running docker builder prune -af ...")
        try:
            subprocess.run(
                ["docker", "builder", "prune", "-af"], check=False, timeout=600
            )
        except subprocess.TimeoutExpired:
            console.print("  [yellow]Warning: docker builder prune timed out[/yellow]")

    return attempted


def _print_cleanup_summary(before_free: int, after_free: int) -> None:
    root = "C:\\" if sys.platform == "win32" else "/"
    freed = after_free - before_free

    console.print("[bold]Cleanup complete[/bold]")
    console.print("================")
    if freed > 0:
        console.print(f"Freed: [green]{_human_size(freed)}[/green]")
    else:
        console.print("Freed: 0 (space may be reclaimed asynchronously by APFS)")

    total = shutil.disk_usage(root).total
    before_pct = int((total - before_free) * 100 / total) if total else 0
    after_pct = int((total - after_free) * 100 / total) if total else 0
    console.print(
        f"Before: {_human_size(before_free)} free / {_human_size(total)} total ({before_pct}% used)"
    )
    console.print(
        f"After:  {_human_size(after_free)} free / {_human_size(total)} total ({after_pct}% used)"
    )


def _run_fix(
    targets: list[ScanTarget], skip_confirm: bool, cache: SizeCache | None = None
) -> None:
    root = "C:\\" if sys.platform == "win32" else "/"
    before_free = shutil.disk_usage(root).free
    all_attempted: list[Path] = []

    console.print()
    console.print("[bold]=== Cleanup ===[/bold]")
    console.print()

    for tier in (1, 2, 3, 4):
        tier_targets = [
            t
            for t in targets
            if t.tier == tier and (t.size_bytes > 0 or t.label == "docker system")
        ]

        if not tier_targets:
            continue

        tier_total = sum(
            t.size_bytes for t in tier_targets if t.label != "docker system"
        )
        label = _TIER_LABELS.get(tier, f"Tier {tier}")
        console.print(f"[cyan]{label} (~{_human_size(tier_total)})[/cyan]")

        if not skip_confirm and not _confirm(f"Clean tier {tier}?"):
            console.print("  [yellow]Skipped[/yellow]")
            console.print()
            continue

        all_attempted.extend(_execute_cleanup(tier_targets))
        console.print("  [green]Done[/green]")
        console.print()

    if cache is not None and all_attempted:
        cache.invalidate(all_attempted)

    after_free = shutil.disk_usage(root).free
    _print_cleanup_summary(before_free, after_free)


# ---------------------------------------------------------------------------
# Interactive mode
# ---------------------------------------------------------------------------


_SELECT_ALL = "__select_all__"
_SELECT_ALL_INCREMENTAL = "__select_all_incremental__"
_SELECT_ALL_CACHE = "__select_all_cache__"
_SELECT_ALL_TARGET = "__select_all_target__"
_SELECT_ALL_DOCKER = "__select_all_docker__"


def _interactive_select(targets: list[ScanTarget]) -> list[ScanTarget]:
    from InquirerPy import inquirer
    from InquirerPy.base.control import Choice
    from InquirerPy.separator import Separator

    incrementals = [
        t for t in targets if t.category == "incremental" and t.size_bytes > 0
    ]
    caches = [t for t in targets if t.category == "cache" and t.size_bytes > 0]
    rust_targets = [t for t in targets if t.category == "target" and t.size_bytes > 0]
    docker_targets = [t for t in targets if t.category == "docker" and t.size_bytes > 0]

    all_with_size = [t for t in targets if t.size_bytes > 0]
    if not all_with_size:
        console.print("[dim]No targets with size > 0 found.[/dim]")
        return []

    choices: list = []

    grand_total = _human_size(sum(t.size_bytes for t in all_with_size))
    choices.append(Choice(value=_SELECT_ALL, name=f"Select all ({grand_total})"))
    choices.append(Separator())

    section_map = {
        _SELECT_ALL_INCREMENTAL: incrementals,
        _SELECT_ALL_CACHE: caches,
        _SELECT_ALL_TARGET: rust_targets,
        _SELECT_ALL_DOCKER: docker_targets,
    }

    if incrementals:
        total = _human_size(sum(t.size_bytes for t in incrementals))
        choices.append(Separator(f"── Rust incremental caches ({total}) ──"))
        choices.append(
            Choice(
                value=_SELECT_ALL_INCREMENTAL,
                name=f"Select all Rust incremental caches ({total})",
            )
        )
        for t in sorted(incrementals, key=lambda t: t.size_bytes, reverse=True):
            choices.append(
                Choice(
                    value=t,
                    name=f"  {_short_path(t.path)} ({_human_size(t.size_bytes)})",
                )
            )

    if caches:
        total = _human_size(sum(t.size_bytes for t in caches))
        choices.append(Separator(f"── Package caches ({total}) ──"))
        choices.append(
            Choice(
                value=_SELECT_ALL_CACHE,
                name=f"Select all Package caches ({total})",
            )
        )
        for t in sorted(caches, key=lambda t: t.size_bytes, reverse=True):
            choices.append(
                Choice(
                    value=t,
                    name=f"  {_short_path(t.path)} ({_human_size(t.size_bytes)})",
                )
            )

    if rust_targets:
        total = _human_size(sum(t.size_bytes for t in rust_targets))
        choices.append(Separator(f"── Rust target dirs ({total}) ──"))
        choices.append(
            Choice(
                value=_SELECT_ALL_TARGET,
                name=f"Select all Rust target dirs ({total})",
            )
        )
        for t in sorted(rust_targets, key=lambda t: t.size_bytes, reverse=True):
            choices.append(
                Choice(
                    value=t,
                    name=f"  {_short_path(t.path)} ({_human_size(t.size_bytes)})",
                )
            )

    if docker_targets:
        total = _human_size(sum(t.size_bytes for t in docker_targets))
        choices.append(Separator(f"── Docker ({total}) ──"))
        choices.append(
            Choice(
                value=_SELECT_ALL_DOCKER,
                name=f"Select all Docker ({total})",
            )
        )
        for t in docker_targets:
            name = (
                "  Docker system prune"
                if t.label == "docker system"
                else f"  {_short_path(t.path)} ({_human_size(t.size_bytes)})"
            )
            choices.append(Choice(value=t, name=name))

    selected_raw = inquirer.checkbox(
        message="Select items to clean (space to toggle, enter to confirm):",
        choices=choices,
    ).execute()

    if _SELECT_ALL in selected_raw:
        return all_with_size

    result: list[ScanTarget] = []
    for item in selected_raw:
        group = section_map.get(item)
        if group is not None:
            result.extend(group)
        elif isinstance(item, ScanTarget):
            result.append(item)

    seen: set[int] = set()
    deduped: list[ScanTarget] = []
    for t in result:
        if id(t) not in seen:
            seen.add(id(t))
            deduped.append(t)
    return deduped


def _run_fix_selected(
    targets: list[ScanTarget], cache: SizeCache | None = None
) -> None:
    root = "C:\\" if sys.platform == "win32" else "/"
    before_free = shutil.disk_usage(root).free

    console.print()
    console.print("[bold]=== Cleanup ===[/bold]")
    console.print()

    attempted = _execute_cleanup(targets)

    if cache is not None and attempted:
        cache.invalidate(attempted)

    console.print()
    after_free = shutil.disk_usage(root).free
    _print_cleanup_summary(before_free, after_free)


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

_DEFAULT_WORKERS = min(os.cpu_count() or 4, 16)


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="disk-cleanup",
        description="Cross-platform disk usage reporter and cleaner",
    )
    parser.add_argument(
        "command",
        nargs="?",
        default="check",
        choices=["check", "fix", "interactive"],
        help="check (default), fix (all tiers), or interactive (select items to clean)",
    )
    parser.add_argument(
        "-y",
        "--yes",
        action="store_true",
        help="Skip confirmation prompts",
    )
    default_dev_dir = Path(
        os.environ.get("DISK_CLEANUP_DEV_DIR", str(Path.home() / "Development"))
    )
    parser.add_argument(
        "--dev-dir",
        type=Path,
        default=default_dev_dir,
        help=f"Development directory to scan (default: $DISK_CLEANUP_DEV_DIR or ~/Development, currently: {_short_path(default_dev_dir)})",
    )
    parser.add_argument(
        "--no-color",
        action="store_true",
        help="Disable colored output",
    )
    parser.add_argument(
        "--workers",
        type=int,
        default=_DEFAULT_WORKERS,
        help=f"Parallel thread count for size computation (default: {_DEFAULT_WORKERS}, based on CPU count, capped at 16)",
    )
    parser.add_argument(
        "--cache-ttl",
        type=float,
        default=300.0,
        help="Cache TTL for du results in seconds (default: 300, 0 to disable)",
    )
    parser.add_argument(
        "--no-cache",
        action="store_true",
        help="Bypass size cache and force fresh du scan",
    )
    args = parser.parse_args()

    if args.command == "interactive" and args.yes:
        parser.error("--yes cannot be used with interactive mode")

    if args.no_color:
        global console
        console = Console(no_color=True)

    dev_dir = args.dev_dir.resolve()
    home = Path.home().resolve()
    if dev_dir == home or dev_dir == Path("/"):
        parser.error("--dev-dir must not be home or root itself")
    if not str(dev_dir).startswith(str(home) + os.sep):
        parser.error(f"--dev-dir must be under $HOME, got: {dev_dir}")

    cache_dir = Path(os.environ.get("XDG_CACHE_HOME", str(Path.home() / ".cache")))
    cache_path = cache_dir / "disk-cleanup" / "sizes.json"
    cache = (
        None
        if (args.no_cache or args.cache_ttl == 0)
        else SizeCache(cache_path, args.cache_ttl)
    )

    targets = _scan(dev_dir, args.workers, cache=cache)

    if args.command == "check":
        _print_report(targets)
    elif args.command == "fix":
        _print_report(targets)
        _run_fix(targets, skip_confirm=args.yes, cache=cache)
    elif args.command == "interactive":
        _print_report(targets)
        selected = _interactive_select(targets)
        if selected:
            _run_fix_selected(selected, cache=cache)


if __name__ == "__main__":
    main()
