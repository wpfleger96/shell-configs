def _format_discovery_rows(items: list[DiscoveryItem], term_width: int) -> list[str]:
    SIZE_COL = 8
    DATE_COL = 12  # " YYYY-MM-DD "
    INDENT = 2

    rows = []
    for t in items:
        stale_tag = f"[stale {_human_age(t.mtime)}]" if t.is_stale else ""
        stale_plain = f" {stale_tag}" if stale_tag else ""
        stale_str = f" [dim]{stale_tag.replace('[', '\\[')}[/dim]" if stale_tag else ""
        max_path_width = term_width - INDENT - SIZE_COL - DATE_COL - len(stale_plain)
        path_str = _short_path(t.path)
        if len(path_str) > max_path_width:
            path_str = "…" + path_str[-(max_path_width - 1) :]
        plain_size = _human_size(t.size_bytes)
        date_str = time.strftime("%Y-%m-%d", time.localtime(t.mtime))
        padding = (
            term_width
            - INDENT
            - len(path_str)
            - len(plain_size)
            - DATE_COL
            - len(stale_plain)
        )
        rows.append(
            f"  {path_str}{' ' * max(1, padding)}{_color_size(t.size_bytes)}  {date_str}{stale_str}"
        )
    return rows


def _print_discovery_report(items: list[DiscoveryItem], term_width: int) -> None:
    visible = [t for t in items if t.size_bytes >= _MIN_DISPLAY_BYTES]
    if not visible:
        return

    console.print("[bold]Large Files (outside known caches)[/bold]")

    # Group by category
    by_category: dict[str, list[DiscoveryItem]] = {}
    for item in visible:
        by_category.setdefault(item.category, []).append(item)

    from InquirerPy.separator import Separator

    # Sort categories by total bytes descending
    sorted_categories = sorted(
        by_category.items(),
        key=lambda kv: sum(i.size_bytes for i in kv[1]),
        reverse=True,
    )

    grand_total = 0
    for category, cat_items in sorted_categories:
        total_bytes = sum(i.size_bytes for i in cat_items)
        grand_total += total_bytes
        total_str = _human_size(total_bytes)
        console.print(Separator(f"── {category} ({total_str}) ──"))
        for line in _format_discovery_rows(cat_items, term_width):
            console.print(line)

    console.print(f"[bold]Total discovered: {_human_size(grand_total)}[/bold]")


