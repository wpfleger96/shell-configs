#!/usr/bin/env bash

set -euo pipefail

DEV_DIR="$HOME/Development"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

if [[ ! -t 1 ]]; then
    RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' NC=''
fi

SKIP_CONFIRM=false
MODE="check"

# --- Helpers ---

human_size() {
    local kb=$1
    if (( kb >= 1048576 )); then
        printf "%.1fG" "$(echo "scale=1; $kb / 1048576" | bc)"
    elif (( kb >= 1024 )); then
        printf "%.0fM" "$(echo "scale=0; $kb / 1024" | bc)"
    else
        printf "%dK" "$kb"
    fi
}

color_size() {
    local kb=$1
    local text
    text=$(human_size "$kb")
    if (( kb >= 10485760 )); then
        printf "${RED}%s${NC}" "$text"
    elif (( kb >= 1048576 )); then
        printf "${YELLOW}%s${NC}" "$text"
    else
        printf "%s" "$text"
    fi
}

short_path() {
    echo "$1" | sed "s|^$HOME|~|"
}

dir_size_kb() {
    du -sk "$1" 2>/dev/null | cut -f1 || echo 0
}

get_disk_info() {
    df -k / | awk 'NR==2 { print $2, $4 }'
}

confirm_action() {
    local action="$1"
    if [[ "$SKIP_CONFIRM" == "true" ]]; then
        return 0
    fi
    printf "${YELLOW}%s${NC}\n" "$action"
    read -p "Continue? (y/N) " -n 1 -r
    echo
    [[ $REPLY =~ ^[Yy]$ ]]
}

# --- Discovery ---

find_incremental_dirs() {
    find "$DEV_DIR" -type d -name "incremental" \
        -path "*/target/debug/incremental" -o \
        -path "*/target/release/incremental" \
        2>/dev/null | sort
}

find_target_dirs() {
    find "$DEV_DIR" -type d -name "target" -maxdepth 5 \
        2>/dev/null | while read -r dir; do
        # Only include if it looks like a Rust target dir (has debug/ or release/)
        if [[ -d "$dir/debug" || -d "$dir/release" ]]; then
            echo "$dir"
        fi
    done | sort
}

# --- Cache locations ---

declare -a CACHE_ENTRIES=(
    "$HOME/.cache/uv|uv cache clean"
    "$HOME/Library/Caches/hermit|rm -rf"
    "$HOME/.npm/_cacache|npm cache clean --force"
    "$HOME/Library/Caches/Homebrew|brew cleanup"
    "$HOME/.gradle/caches|rm -rf"
)

# --- Scan ---

scan() {
    local total_incremental_kb=0
    local total_target_kb=0
    local total_cache_kb=0
    local docker_kb=0

    echo -e "${BOLD}Disk Usage Report${NC}"
    echo "================="

    local disk_info
    disk_info=$(get_disk_info)
    local total_disk_kb avail_kb
    total_disk_kb=$(echo "$disk_info" | cut -d' ' -f1)
    avail_kb=$(echo "$disk_info" | cut -d' ' -f2)
    local pct=$(( (total_disk_kb - avail_kb) * 100 / total_disk_kb ))
    echo -e "Disk: ${BOLD}$(human_size "$avail_kb")${NC} free / $(human_size "$total_disk_kb") total (${pct}% used)"
    echo ""

    # Rust incremental caches
    echo -e "${BLUE}Rust incremental caches${NC} (safe to clear, first rebuild slightly slower):"
    local found_incremental=false
    while IFS= read -r dir; do
        [[ -z "$dir" ]] && continue
        local kb
        kb=$(dir_size_kb "$dir")
        (( kb < 1024 )) && continue
        total_incremental_kb=$(( total_incremental_kb + kb ))
        printf "  %-70s %s\n" "$(short_path "$dir")" "$(color_size "$kb")"
        found_incremental=true
    done < <(find_incremental_dirs)
    if [[ "$found_incremental" == "false" ]]; then
        echo "  (none found)"
    fi
    echo -e "  ${BOLD}Subtotal: $(human_size "$total_incremental_kb")${NC}"
    echo ""

    # Rust target dirs (full)
    echo -e "${BLUE}Rust target dirs${NC} (full — clearing requires full rebuild):"
    local found_targets=false
    while IFS= read -r dir; do
        [[ -z "$dir" ]] && continue
        local kb
        kb=$(dir_size_kb "$dir")
        (( kb < 1024 )) && continue
        total_target_kb=$(( total_target_kb + kb ))
        printf "  %-70s %s\n" "$(short_path "$dir")" "$(color_size "$kb")"
        found_targets=true
    done < <(find_target_dirs)
    if [[ "$found_targets" == "false" ]]; then
        echo "  (none found)"
    fi
    echo -e "  ${BOLD}Subtotal: $(human_size "$total_target_kb")${NC}"
    echo ""

    # Package caches
    echo -e "${BLUE}Package caches${NC} (safe to clear, re-downloaded on demand):"
    for entry in "${CACHE_ENTRIES[@]}"; do
        local path="${entry%%|*}"
        if [[ -d "$path" ]]; then
            local kb
            kb=$(dir_size_kb "$path")
            (( kb < 1024 )) && continue
            total_cache_kb=$(( total_cache_kb + kb ))
            printf "  %-70s %s\n" "$(short_path "$path")" "$(color_size "$kb")"
        fi
    done
    echo -e "  ${BOLD}Subtotal: $(human_size "$total_cache_kb")${NC}"
    echo ""

    # Docker
    local docker_raw="$HOME/Library/Containers/com.docker.docker/Data/vms/0/data/Docker.raw"
    if [[ -f "$docker_raw" ]]; then
        echo -e "${BLUE}Docker${NC}:"
        docker_kb=$(( $(stat -f%z "$docker_raw" 2>/dev/null || echo 0) / 1024 ))
        printf "  %-70s %s\n" "$(short_path "$docker_raw")" "$(color_size "$docker_kb")"
        echo ""
    fi

    local reclaimable_kb=$(( total_incremental_kb + total_cache_kb ))
    echo -e "${BOLD}Total reclaimable (incremental + caches): $(human_size "$reclaimable_kb")${NC}"
    if (( docker_kb > 0 )); then
        echo -e "Docker disk image on-disk: $(human_size "$docker_kb") (run ${CYAN}docker system prune${NC} to reclaim)"
    fi

    # Export for fix mode
    SCAN_INCREMENTAL_KB=$total_incremental_kb
    SCAN_CACHE_KB=$total_cache_kb
}

# --- Fix ---

fix() {
    local before_info
    before_info=$(get_disk_info)
    local before_avail_kb
    before_avail_kb=$(echo "$before_info" | cut -d' ' -f2)
    local total_disk_kb
    total_disk_kb=$(echo "$before_info" | cut -d' ' -f1)

    echo ""
    echo -e "${BOLD}=== Cleanup ===${NC}"
    echo ""

    # Tier 1: Rust incremental caches
    if (( SCAN_INCREMENTAL_KB > 1024 )); then
        echo -e "${CYAN}Tier 1: Rust incremental caches (~$(human_size "$SCAN_INCREMENTAL_KB"))${NC}"
        if confirm_action "Delete all Rust incremental compilation caches?"; then
            while IFS= read -r dir; do
                [[ -z "$dir" ]] && continue
                local kb
                kb=$(dir_size_kb "$dir")
                (( kb < 1024 )) && continue
                echo -e "  Removing $(short_path "$dir") ($(human_size "$kb"))..."
                rm -rf "$dir"
            done < <(find_incremental_dirs)
            echo -e "  ${GREEN}Done${NC}"
        else
            echo -e "  ${YELLOW}Skipped${NC}"
        fi
        echo ""
    fi

    # Tier 2: Package caches
    if (( SCAN_CACHE_KB > 1024 )); then
        echo -e "${CYAN}Tier 2: Package caches (~$(human_size "$SCAN_CACHE_KB"))${NC}"
        if confirm_action "Clean all package manager caches?"; then
            for entry in "${CACHE_ENTRIES[@]}"; do
                local path="${entry%%|*}"
                local cmd="${entry#*|}"
                if [[ ! -d "$path" ]]; then
                    continue
                fi
                local kb
                kb=$(dir_size_kb "$path")
                (( kb < 1024 )) && continue
                local display_path
                display_path=$(short_path "$path")

                case "$cmd" in
                    "rm -rf")
                        echo -e "  Removing $display_path ($(human_size "$kb"))..."
                        rm -rf "$path"
                        ;;
                    "uv cache clean")
                        if command -v uv &>/dev/null; then
                            echo -e "  Running uv cache clean ($display_path, $(human_size "$kb"))..."
                            uv cache clean 2>/dev/null || true
                        else
                            echo -e "  ${YELLOW}Skipping $display_path (uv not found)${NC}"
                        fi
                        ;;
                    "npm cache clean --force")
                        if command -v npm &>/dev/null; then
                            echo -e "  Running npm cache clean ($display_path, $(human_size "$kb"))..."
                            npm cache clean --force 2>/dev/null || true
                        else
                            echo -e "  ${YELLOW}Skipping $display_path (npm not found)${NC}"
                        fi
                        ;;
                    "brew cleanup")
                        if command -v brew &>/dev/null; then
                            echo -e "  Running brew cleanup ($display_path, $(human_size "$kb"))..."
                            brew cleanup 2>/dev/null || true
                        else
                            echo -e "  ${YELLOW}Skipping $display_path (brew not found)${NC}"
                        fi
                        ;;
                esac
            done
            echo -e "  ${GREEN}Done${NC}"
        else
            echo -e "  ${YELLOW}Skipped${NC}"
        fi
        echo ""
    fi

    # Tier 3: Docker
    if command -v docker &>/dev/null && docker info &>/dev/null 2>&1; then
        echo -e "${CYAN}Tier 3: Docker cleanup${NC}"
        if confirm_action "Run docker builder prune and docker system prune?"; then
            echo "  Running docker builder prune..."
            docker builder prune -af 2>/dev/null || true
            echo "  Running docker system prune..."
            docker system prune -af 2>/dev/null || true
            echo -e "  ${GREEN}Done${NC}"
        else
            echo -e "  ${YELLOW}Skipped${NC}"
        fi
        echo ""
    fi

    # Summary
    local after_info
    after_info=$(get_disk_info)
    local after_avail_kb
    after_avail_kb=$(echo "$after_info" | cut -d' ' -f2)
    local freed_kb=$(( after_avail_kb - before_avail_kb ))

    echo -e "${BOLD}Cleanup complete${NC}"
    echo "================"
    if (( freed_kb > 0 )); then
        echo -e "Freed: ${GREEN}$(human_size "$freed_kb")${NC}"
    else
        echo "Freed: 0 (space may be reclaimed asynchronously by APFS)"
    fi
    local before_pct=$(( (total_disk_kb - before_avail_kb) * 100 / total_disk_kb ))
    local after_pct=$(( (total_disk_kb - after_avail_kb) * 100 / total_disk_kb ))
    echo "Before: $(human_size "$before_avail_kb") free / $(human_size "$total_disk_kb") total (${before_pct}% used)"
    echo "After:  $(human_size "$after_avail_kb") free / $(human_size "$total_disk_kb") total (${after_pct}% used)"
}

# --- Main ---

show_help() {
    echo "Usage: disk-cleanup [check|fix] [--yes]"
    echo ""
    echo "Commands:"
    echo "  check   Report disk usage by category (default)"
    echo "  fix     Report then clean, with confirmation prompts"
    echo ""
    echo "Flags:"
    echo "  --yes, -y   Skip confirmation prompts"
    echo "  --help, -h  Show this help"
}

main() {
    local args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --yes|-y) SKIP_CONFIRM=true; shift ;;
            --help|-h) show_help; exit 0 ;;
            -*) echo "Unknown flag: $1" >&2; show_help; exit 1 ;;
            *) args+=("$1"); shift ;;
        esac
    done

    MODE="${args[0]:-check}"

    case "$MODE" in
        check)
            scan
            ;;
        fix)
            scan
            fix
            ;;
        *)
            echo "Unknown command: $MODE" >&2
            show_help
            exit 1
            ;;
    esac
}

main "$@"
